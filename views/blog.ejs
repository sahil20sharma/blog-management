<!DOCTYPE html>
<html lang="en">

<head>

    <%- include("./partials/head") %>

        <title>Blog</title>
</head>

<body>
    <%- include("./partials/nav") %>
        <div class="conatiner mt-4">
            <h1>
                <%= blog.title %>
            </h1>
            <img src="<%= blog.coverimageurl %>" width="70px" />
            <p>
                <%= blog.body %>
            </p>


        </div>


        <div class="conatiner mt-4">
            <img src="<%= blog.createdby?.profileimageurl || '/default-profile.png' %>" />
            <%= blog.createdby?.fullname || 'Deleted User' %>

        </div>

        <div class="container mt-4">
            <h1>Comment (<%= comments.length %>)</h1>
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post">


                    <div class="mb-3">

                        <input type="text" class="form-control" id="content" name="content"
                            placeholder="Enter your comment">

                        <button class="btn-primary" type="submit">Add</button>

                    </div>
                </form>

                <% } %>
                    <div class="mt-3">
                        <% comments.forEach(comment=> { %>
                            <div class="mb-2">
                                <img src="<%= comment.createdby?.profileimageurl || '/default-profile.png' %>"
                                    width="60px" />
                                <strong>
                                    <%= comment.createdby?.fullname || 'Deleted User' %>
                                </strong>
                                <pre><%= comment.content %></pre>
                            </div>
                            <% }) %>


                    </div>
                    <!--only owner can delete or see delete button-->
                    <% if (user && blog.createdby._id.toString()===user._id.toString()) { %>
                        <form action="/blog/delete/<%= blog._id %>" method="POST">
                            <button class="btn btn-danger mt-2"
                                onclick="return confirm('Are you sure you want to delete this blog?')">
                                Delete Blog
                            </button>
                        </form>
                        <% } %>
        </div>
        <%- include('./partials/scripts') %>
</body>

























</html>